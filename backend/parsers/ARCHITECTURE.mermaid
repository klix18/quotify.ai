flowchart TD
    classDef frontend fill:#e8f4fd,stroke:#1761d4,color:#1761d4
    classDef core fill:#1761d4,stroke:#0d4aaa,color:#fff
    classDef skill fill:#f0fdf4,stroke:#16a34a,color:#16a34a
    classDef schema fill:#fefce8,stroke:#ca8a04,color:#92400e
    classDef model fill:#fdf4ff,stroke:#9333ea,color:#6b21a8
    classDef fallback fill:#fff7ed,stroke:#ea580c,color:#c2410c
    classDef cache fill:#eef2ff,stroke:#4f46e5,color:#3730a3
    classDef output fill:#f0f9ff,stroke:#0891b2,color:#0e7490

    FE["🖥️ Frontend\nPOST /api/parse-quote\n{ insurance_type, file }"]:::frontend

    subgraph UNIFIED["unified_parser_api.py — Single Entry Point"]
        direction TB
        EP["📡 /api/parse-quote\naccepts any insurance_type"]:::core
        SL["📚 skill_loader.py\nload + cache skills/parse_{type}/SKILL.md"]:::skill
        SR["🗂️ schema_registry.py\nschema + normalizer for type"]:::schema
        EP --> SL
        EP --> SR
    end

    subgraph SKILLS["Skills System  ·  skills/parse_*/SKILL.md (v2)"]
        direction LR
        S1["🏠 parse_homeowners/SKILL.md\nv2.0 · carriers baked in"]:::skill
        S2["🚗 parse_auto/SKILL.md\nv2.0 · carriers baked in"]:::skill
        S3["🏢 parse_dwelling/SKILL.md\nv2.0 · carriers baked in"]:::skill
        S4["🏗️ parse_commercial/SKILL.md\nv2.0 · base only"]:::skill
        S5["📦 parse_bundle/SKILL.md\nv2.0\n@include homeowners\n@include auto"]:::skill
    end

    subgraph CACHE["System-Prompt Cache  ·  client.caches (TTL 1h)"]
        direction TB
        CKEY["🔑 cache key\n(insurance_type, supplements, skill_version)"]:::cache
        CREG["🗃️ _SYSTEM_CACHE_REGISTRY\nprocess-local name lookup"]:::cache
        CGEM["☁️ Gemini explicit cache\ncachedContents/...\nCORE_PROMPT + full SKILL.md"]:::cache
        CKEY --> CREG
        CREG --> CGEM
    end

    subgraph EXTRACT["Extraction — Single Pass  ·  gemini-2.5-flash"]
        direction LR
        EXSYS["System (cached):\nCORE_PROMPT\n+ full SKILL.md\n+ wind/hail or bundle_separate supplement"]:::model
        EXUSR["User:\n'Extract all {type} fields'\nresponse_schema = type schema\nthinking_budget = 512"]:::model
        EXOUT["→ JSON stream\n→ final_patch events\n→ normalized result + confidence"]:::output
        EXSYS --- EXUSR --> EXOUT
    end

    subgraph FALLBACK["Fallback Chain  ·  _model_fallback.py + _openai_fallback.py"]
        direction LR
        FB1["⚡ Gemini 503 / overload\ndetected on first chunk"]:::fallback
        FB2["→ OpenAI Responses API\ngpt-4o-mini → gpt-4o\nsystem_instruction inline (no cache)"]:::fallback
        FB1 --> FB2
    end

    NRM["🔧 post_process\n(per type via schema_registry)\nfill defaults · flatten confidence\nlenient JSON recovery"]:::schema
    WSG["✍️ why_selected_generator\nsingle Gemini Flash call\nskill type passed through"]:::core
    OUT["📤 Streaming ndjson\nstatus · skill_loaded\nfinal_patch · result"]:::output

    FE --> EP
    SL -.->|reads| SKILLS
    SR -.->|provides schema| EXTRACT
    EP --> CACHE
    CACHE -.->|cached_content=name| EXTRACT
    EP --> EXTRACT
    EXTRACT -.->|on error| FALLBACK
    EXTRACT --> NRM
    NRM --> WSG
    WSG --> OUT
    OUT --> FE

    subgraph FUTURE["🔮 Future Agent Capabilities"]
        direction TB
        CAP1["🔍 Carrier-aware routing\ndetect carrier once, route to\nper-carrier sub-skill overrides"]:::skill
        CAP2["🔁 Selective self-healing\noptionally re-query only\nvery-low-confidence fields"]:::core
        CAP3["📊 Skill Versioning\nVERSION header per skill\nlogged with every parse event"]:::skill
        CAP4["🧩 Skill Composition\nbundle @includes home + auto\nskills are composable units"]:::skill
        CAP5["🧠 Carrier Memory\nremember carrier quirks per org\nauto-inject learned hints"]:::core
    end
